# optional local overrides for [server] in config/platform.toml
# SERVER_HOST=127.0.0.1
# SERVER_PORT=8000
# SERVER_PUBLIC_BASE_URL=https://runtime.example.com

# provider secrets; model/profile selection lives in config/models.toml
OPENAI_API_KEY=
OPENAI_API_BASE=
MINIMAX_API_KEY=
MINIMAX_API_BASE=

# local storage
DATABASE_URL=sqlite:///./data/runtime.db

# tracing backend secrets
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# optional channel secrets
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_BASE_URL=https://open.feishu.cn
